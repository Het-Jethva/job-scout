OPENROUTER_API_KEY=""
# Set this per environment so auth redirects point at the current Vercel URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# Runtime DB connection. For Supabase Prisma deployments, use the shared pooler
# transaction-mode URL on port 6543 and append ?pgbouncer=true.
DATABASE_URL=""
# Migration DB connection. Use the Supabase session-mode/direct URL on port 5432.
# If omitted, prisma.config.ts will derive it from a Supabase 6543 pooler URL.
DIRECT_URL=""
# Optional: The Muse supports higher request limits with an API key.
THEMUSE_API_KEY=""
# Optional: remote LaTeX renderer for higher-fidelity PDF output.
LATEX_RESUME_RENDER_URL=""
LATEX_RESUME_RENDER_TOKEN=""
